# Configuración del Backend - Select Dance Studio
PORT=5000
NODE_ENV=production

# Base de Datos
DB_HOST=db  # Usa 'db' si estás usando Docker, 'localhost' si usas XAMPP local
DB_USER=usuario_db
DB_PASSWORD=contraseña_db
DB_NAME=select_dance_db

# Seguridad
JWT_SECRET=tu_secreto_super_seguro_aqui

# Frontend URL (para CORS)
FRONTEND_URL=https://tu-dominio.com

# WhatsApp / Twilio (Si aplica)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
